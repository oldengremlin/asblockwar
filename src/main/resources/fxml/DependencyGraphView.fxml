<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="net.ukrcom.asblockwar.ui.DependencyGraphController">
   <AnchorPane VBox.vgrow="ALWAYS">
      <WebView fx:id="webView"
               AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
               AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
   </AnchorPane>
   <Label fx:id="statusLabel" text="Завантаження...">
      <VBox.margin>
         <Insets bottom="4.0" left="8.0" top="4.0" />
      </VBox.margin>
   </Label>
</VBox>
