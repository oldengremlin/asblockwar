<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="6.0" prefHeight="480.0" prefWidth="680.0" style="-fx-padding: 8;"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="net.ukrcom.asblockwar.ui.FilePickerController">
   <stylesheets>
      <URL value="@../styles/mainwindows.css" />
   </stylesheets>
   <children>
      <SplitPane fx:id="contentSplit" dividerPositions="0.38" VBox.vgrow="ALWAYS">
         <items>
            <TreeView fx:id="dirTree" minWidth="120.0" />
            <ListView fx:id="fileList" minWidth="120.0" />
         </items>
      </SplitPane>
      <HBox spacing="6.0" alignment="CENTER_LEFT">
         <children>
            <Label text="Selected:" />
            <TextField fx:id="selectedPath" HBox.hgrow="ALWAYS" />
         </children>
      </HBox>
      <ButtonBar>
         <buttons>
            <Button fx:id="okButton" text="Select" onAction="#doSelect" defaultButton="true" mnemonicParsing="false" />
            <Button text="Cancel" onAction="#doCancel" cancelButton="true" mnemonicParsing="false" />
         </buttons>
      </ButtonBar>
   </children>
</VBox>
