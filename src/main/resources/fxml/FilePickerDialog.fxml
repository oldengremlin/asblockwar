<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="480.0" prefWidth="680.0" spacing="6.0" style="-fx-padding: 8;" stylesheets="@../styles/mainwindows.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.ukrcom.asblockwar.ui.FilePickerController">
   <children>
      <SplitPane fx:id="contentSplit" dividerPositions="0.38" VBox.vgrow="ALWAYS">
         <items>
            <TreeView fx:id="dirTree" minWidth="120.0" />
            <ListView fx:id="fileList" minWidth="120.0" />
         </items>
      </SplitPane>
      <HBox alignment="CENTER_LEFT" spacing="6.0">
         <children>
            <Label text="Selected:" />
            <TextField fx:id="selectedPath" styleClass="text-field" HBox.hgrow="ALWAYS" />
         </children>
      </HBox>
      <ButtonBar>
         <buttons>
            <Button fx:id="okButton" defaultButton="true" mnemonicParsing="false" onAction="#doSelect" text="Select" />
            <Button cancelButton="true" mnemonicParsing="false" onAction="#doCancel" text="Cancel" />
         </buttons>
      </ButtonBar>
   </children>
</VBox>
