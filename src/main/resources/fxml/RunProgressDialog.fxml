<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<VBox spacing="6.0" prefHeight="500.0" prefWidth="720.0" style="-fx-padding: 8;"
      stylesheets="@../styles/mainwindows.css"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="net.ukrcom.asblockwar.ui.RunProgressController">
   <children>
      <ProgressBar fx:id="progressBar" maxWidth="Infinity" prefHeight="16.0" progress="-1.0" />
      <WebView fx:id="logView" VBox.vgrow="ALWAYS" prefHeight="440.0" />
      <ButtonBar>
         <buttons>
            <Button fx:id="closeButton" mnemonicParsing="false" text="Close" onAction="#doClose" disable="true" />
         </buttons>
      </ButtonBar>
   </children>
</VBox>
